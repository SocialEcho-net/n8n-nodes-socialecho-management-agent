{
  "name": "n8n-nodes-socialecho-management-agent",
  "version": "0.1.6",
  "description": "n8n community node for SocialEcho external APIs (team/account/article/report). Uses GET with JSON body per OpenAPI; accepts business code 0 or 200.",
  "license": "MIT",
  "homepage": "https://github.com/SocialEcho-net/n8n-nodes-socialecho-management-agent",
  "author": {
    "name": "SocialEcho Team",
    "email": "support@socialecho.net"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SocialEcho-net/n8n-nodes-socialecho-management-agent.git"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n-community-node",
    "n8n",
    "n8n-nodes",
    "socialecho",
    "social-media"
  ],
  "files": [
    "dist",
    "platform-publish-limits_cn.md",
    "platform-publish-limits_en.md"
  ],
  "main": "dist/nodes/SocialEcho/SocialEcho.node.js",
  "types": "dist/nodes/SocialEcho/SocialEcho.node.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -w -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=18.17"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "n8n-workflow": "^1.93.0",
    "typescript": "^5.6.3"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SocialEchoApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SocialEcho/SocialEcho.node.js"
    ]
  }
}
